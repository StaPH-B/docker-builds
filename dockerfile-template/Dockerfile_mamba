##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####
##### Step 1. Set up the base image in the 'app' stage.                 #####
##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####

##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####
##### Conda/Micromamba is a powerful package manager for bioinformatics. #####
##### This template uses Ubuntu Noble (24.04) as the base OS for        #####
##### long-term support and the latest security updates.                #####
##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####

# 'FROM' defines the base docker image.
# We are using Micromamba 2.5.0 built on Ubuntu 24.04 (Noble).
FROM mambaorg/micromamba:2.5.0-noble AS app

# List all software versions as ARGs near the top of the dockerfile
ARG SOFTWARENAME_VERSION="1.0.4"

# Micromamba images start as 'mambauser'. We switch to root to install 
# system dependencies and setup project-specific users.
USER root

# 'LABEL' instructions tag the image with metadata.
# NOTE: All 'org.opencontainers' labels are REQUIRED to pass StaPH-B CI tests.
LABEL \
      # The date this image was last updated (YYYY-MM-DD). Manually update this!
      org.opencontainers.image.created="2024-05-20" \
      # The exact base image (Must match the FROM instruction above)
      org.opencontainers.image.base.name="mambaorg/micromamba:2.5.0-noble" \
      # The name of the software (e.g., "Prokka")
      org.opencontainers.image.title="SOFTWARENAME" \
      # The version of the software itself
      org.opencontainers.image.version="${SOFTWARENAME_VERSION}" \
      # The version of THIS Dockerfile (increment if you change the build logic)
      org.opencontainers.image.revision="1" \
      # A human-readable description of the tool
      org.opencontainers.image.description="This software does X, Y, AND Z!" \
      # The project homepage or GitHub repository
      org.opencontainers.image.url="https://github.com/StaPH-B/docker-builds" \
      # Where users can find instructions or manuals
      org.opencontainers.image.documentation="https://github.com/StaPH-B/docker-builds" \
      # Link to the source code used to build the image
      org.opencontainers.image.source="https://github.com/StaPH-B/docker-builds" \
      # The software license (e.g., MIT, GPL-3.0, Apache-2.0)
      org.opencontainers.image.licenses="GPL-3.0" \
      # The person/group maintaining this Dockerfile (firstName lastName <email@example.com>)
      org.opencontainers.image.authors="firstName lastName <example@email.com>"

# 'RUN' executes code during the build.
RUN apt-get update && apt-get install -y --no-install-recommends \
    deps && \
    apt-get autoclean && rm -rf /var/lib/apt/lists/*

# Install your desired software into the base conda/micromamba environment.
# 'micromamba clean' removes index files and tarballs to keep the image slim.
RUN micromamba install --name base -c conda-forge -c bioconda SOFTWARENAME=${SOFTWARENAME_VERSION} && \
    micromamba clean -a -f -y && \
    mkdir /data

# Setup Non-Root User
# The CI checks to ensure the image does not run as root (UID 0).
# We create the 'staphb' user and ensure they own the /data directory.
RUN groupadd -r staphb && useradd -r -g staphb staphb && chown staphb:staphb /data

# 'ENV' instructions set environment variables.
# We add the conda bin directory to the PATH and set the locale to UTF-8.
ENV PATH="/opt/conda/bin/:${PATH}" \
    LC_ALL=C.UTF-8

# 'WORKDIR' sets the default working directory. 
# StaPH-B Requirement: This MUST be set exactly to /data.
WORKDIR /data

# Switch to the non-root user for the final image.
USER staphb

# 'CMD' instructions set a default command (typically 'tool --help').
CMD [ "tool", "--help" ]


##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####
##### Step 2. Set up the testing stage.                                 #####
##### ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- ----- #####

# A second FROM instruction creates a new stage for automated testing.
FROM app AS test

# CRITICAL: StaPH-B CI requires 'micromamba list' to be run if micromamba is used.
RUN micromamba list -n base

# Set working directory for test inputs & outputs.
WORKDIR /test

# Verify the tool is in the PATH and executable.
RUN softwarename --help && \
    softwarename --version

