# syntax=docker/dockerfile:1

# Use ARG so the version only needs to be defined once at the top.
ARG SOFTWARENAME_VER="1.0.0"

##### ----- STEP 1: BUILDER STAGE ----- #####
# We use a 'builder' stage to compile or download software. 
# This keeps the final 'app' image small by leaving out compilers and 
# temporary files that aren't needed to actually run the tool.
FROM ubuntu:noble AS builder

# Re-declare ARGs so they are available in this stage
ARG SOFTWARENAME_VER

# Install build-time dependencies (e.g., compilers, wget, git)
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    build-essential \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Basic format for downloading from GitHub. 
RUN wget https://github.com/example/tool/archive/v${SOFTWARENAME_VER}.tar.gz && \
    tar -xzf v${SOFTWARENAME_VER}.tar.gz

##### ----- STEP 2: APP STAGE ----- #####
# This is the "real" image that users will pull and run.
FROM ubuntu:noble AS app

# Re-declare ARGs so they are available in this stage
ARG SOFTWARENAME_VER="1.0.0"

# Install Runtime Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    deps \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Setup Non-Root User
# Create a new user because running as 'root' is a security risk.
RUN groupadd -r staphb && useradd -r -g staphb staphb

# 3. Copy only the necessary binaries from the builder stage
COPY --from=builder /tool-${SOFTWARENAME_VER}/bin/* /usr/local/bin/

# Set Environment Variables
# LC_ALL=C ensures consistent text sorting/processing across different systems.
ENV LC_ALL=C \
    PATH="/usr/local/bin:$PATH"

# Set Working Directory to /data
WORKDIR /data

# Required Metadata Labels
# These follow the OCI Image Spec. They help users and automated systems 
# identify what is inside the container.
LABEL \
      # The date this image was last updated (Manually update this!)
      org.opencontainers.image.created="2024-05-20" \
      # The exact base image used for the 'app' stage (Must match the FROM instruction above)
      org.opencontainers.image.base.name="ubuntu:noble" \
      # The name of the software (e.g., "BWA" or "Samtools")
      org.opencontainers.image.title="SoftwareName" \
      # The version of the software itself
      org.opencontainers.image.version="${SOFTWARENAME_VER}" \
      # The version of THIS Dockerfile (increment if you change the build logic)
      org.opencontainers.image.revision="1" \
      # A human-readable description of the tool
      org.opencontainers.image.description="A brief description of what this tool does" \
      # The project homepage or GitHub repository
      org.opencontainers.image.url="https://github.com/StaPH-B/docker-builds" \
      # Where users can find instructions or manuals for the software
      org.opencontainers.image.documentation="https://github.com/StaPH-B/docker-builds" \
      # Link to the source code used to build the image (which is often a GitHub url)
      org.opencontainers.image.source="https://github.com/StaPH-B/docker-builds" \
      # The software license (e.g., MIT, GPL-3.0, Apache-2.0) for the software
      org.opencontainers.image.licenses="GPL-3.0" \
      # The person/group maintaining this Dockerfile
      org.opencontainers.image.authors="firstName lastName <example@email.com>"

# Switch to the non-root user defined earlier
USER staphb

# CMD defines what runs when a user types 'docker run <image>'. 
# Usually, we set this to the tool's help menu.
CMD ["tool", "--help"]

##### ----- STEP 3: TEST STAGE ----- #####
# This stage is used by GitHub Actions to verify the build. 
# It is not pushed to the final registry.
FROM app AS test

# Set working directory for test outputs
WORKDIR /test

# Basic Check: Verify the tool can be found in the PATH and executes.
# This prevents "broken" images from being merged.
RUN tool --version && tool --help

