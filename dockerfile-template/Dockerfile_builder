##### ------------------------------------------------------------------ #####
##### Hardened Multi-Stage Dockerfile Template                           #####
#####                                                                    #####
##### Features                                                           #####
##### - Multi-stage build                                                #####
##### - Minimal runtime image                                            #####
##### - Non-root runtime user                                            #####
##### - OCI metadata labels                                              #####
##### - Checksum verification for downloads                              #####
##### - Clean apt usage                                                  #####
##### - Reproducible build support                                       #####
##### ------------------------------------------------------------------ #####

############################
# Stage 1 — Builder
############################

FROM ubuntu:22.04 AS builder

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive

# ----- Software versions -----
ARG SOFTWARE_VER="1.0.0"
ARG DEPENDENCY_VER="1.0.0"

# ----- Install build dependencies -----
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    ca-certificates \
    wget \
    curl \
    build-essential \
    git \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# ----- Example: Download and verify software -----
# Replace with your software source
# Always verify downloads with SHA256 when possible

ARG SOFTWARE_SHA256="CHECKSUM_HERE"

RUN wget https://example.com/software-${SOFTWARE_VER}.tar.gz \
 && echo "${SOFTWARE_SHA256} software-${SOFTWARE_VER}.tar.gz" | sha256sum -c - \
 && tar -xzf software-${SOFTWARE_VER}.tar.gz \
 && rm software-${SOFTWARE_VER}.tar.gz

# ----- Build software if required -----
# RUN cd software-${SOFTWARE_VER} && make


############################
# Stage 2 — Runtime
############################

FROM ubuntu:22.04 AS app

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive

# ----- Software version ARGs -----
ARG SOFTWARE_VER="1.0.0"

# ----- OCI image metadata -----
LABEL org.opencontainers.image.title="SoftwareName" \
      org.opencontainers.image.description="Generic containerized tool" \
      org.opencontainers.image.version="${SOFTWARE_VER}" \
      org.opencontainers.image.source="https://github.com/your-org/your-repo" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.authors="Maintainer Name"

# ----- Install runtime dependencies -----
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    ca-certificates \
    dependency_a \
    dependency_b \
 && rm -rf /var/lib/apt/lists/*

# ----- Create non-root user -----
RUN useradd --system --create-home --uid 10001 appuser

# ----- Copy compiled binaries from builder -----
COPY --from=builder /build/software-${SOFTWARE_VER}/bin/tool /usr/local/bin/

# ----- Set executable permissions -----
RUN chmod 0755 /usr/local/bin/tool

# ----- Environment variables -----
ENV PATH="/usr/local/bin:$PATH" \
    LC_ALL=C

# ----- Working directory -----
WORKDIR /data

# ----- Switch to non-root user -----
USER appuser

# ----- Default command -----
CMD ["tool", "--help"]


############################
# Stage 3 — Testing
############################

FROM app AS test

WORKDIR /test

# ----- Basic runtime checks -----
RUN tool --help
RUN tool --version

