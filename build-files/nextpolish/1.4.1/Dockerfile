FROM ubuntu:focal as app

ARG NEXTPOLISH_VER="v1.4.1"

LABEL base.image="ubuntu:focal"
LABEL dockerfile.version="1"
LABEL software="NextPolish"
LABEL software.version="1.4.1"
LABEL description="Fast and accurately polish the genome generated by long reads"
LABEL website="https://github.com/Nextomics/NextPolish"
LABEL license="https://github.com/Nextomics/NextPolish/blob/master/LICENSE"
LABEL maintainer="Weifan Lv"
LABEL maintainer.email="lvweifan@pku.edu.cn"

RUN apt-get update && apt-get install -y --no-install-recommends \
  build-essential \
  python3 \
  python3-pip \
  python-is-python3 \
  zlib1g-dev \
  libbz2-dev \
  liblzma-dev \
  libncurses5-dev \
  procps \
  && apt-get autoclean && rm -rf /var/lib/apt/lists/*

RUN pip install paralleltask

RUN mkdir -p /opt

ADD https://github.com/Nextomics/NextPolish/releases/download/${NEXTPOLISH_VER}/NextPolish.tgz ./NextPolish.tgz

RUN tar -xvzf ./NextPolish.tgz -C /opt/ && rm ./NextPolish.tgz && CFLAGS="-fno-common" && cd /opt/NextPolish && make

ENV PATH="/opt/NextPolish:$PATH"

CMD [ "nextPolish", "--help" ]

FROM app AS test

WORKDIR /opt/NextPolish/test_data

RUN nextPolish run.cfg
